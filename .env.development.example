# Configuration Environnement de Développement

# URL du site public
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Base de données (pour la phase suivante intégrée avec PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/pansite_dev

# JWT / Auth Secret
AUTH_SECRET=changeme_dev_secret_key

# Stockage des fichiers (Local pour le développement)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./public/storage

# S3 (Exemple pour préparation future)
# STORAGE_DRIVER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_BUCKET_NAME=

# Analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_MATOMO_URL=
NEXT_PUBLIC_MATOMO_SITE_ID=
