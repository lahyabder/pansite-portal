# Configuration Environnement de Production

# URL du site public (HTTPS obligatoire)
NEXT_PUBLIC_SITE_URL=https://www.pan.mr
NEXT_PUBLIC_ADMIN_URL=https://admin.pan.mr

# Base de données (pour la phase suivante intégrée avec PostgreSQL)
DATABASE_URL=postgresql://prod_user:prod_strong_password@db.pan.mr:5432/pansite_prod?sslmode=require

# JWT / Auth Secret (DOIT ÊTRE GÉNÉRÉ ET SÉCURISÉ)
# Utilisez: openssl rand -base64 32
AUTH_SECRET=

# Stockage des fichiers (Stratégie S3 recommandée pour la prod)
STORAGE_DRIVER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-3
# AWS_BUCKET_NAME=pan-production-ged

# Fallback sur stockage local (si pas S3)
# STORAGE_DRIVER=local
# STORAGE_LOCAL_PATH=/var/www/pansite/storage/uploads

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_MATOMO_URL=https://matomo.pan.mr/
# NEXT_PUBLIC_MATOMO_SITE_ID=1

# Logs (Exemple)
LOG_LEVEL=info
